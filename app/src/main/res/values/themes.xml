<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ArrowVPN" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/arrow_black</item>
        <item name="android:statusBarColor">@color/arrow_black</item>
        <item name="android:navigationBarColor">@color/arrow_black</item>
        <item name="android:navigationBarDividerColor">@color/arrow_black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.ArrowVPN" parent="Base.Theme.ArrowVPN" />

    <style name="Theme.ArrowVPN.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/arrow_black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_transparent_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.ArrowVPN</item>
    </style>
</resources>